{
  "name": "opencode-injection-guard",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenCode plugin that detects prompt injection in tool call outputs using an LLM judge",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist *.tsbuildinfo && tsc",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "prompt-injection",
    "security",
    "guardrails",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/remorses/opencode-injection-guard"
  },
  "homepage": "https://github.com/remorses/opencode-injection-guard",
  "bugs": "https://github.com/remorses/opencode-injection-guard/issues",
  "license": "MIT",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.7",
    "@opencode-ai/sdk": "^1.3.7",
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opencode-ai/sdk": "*"
  }
}
